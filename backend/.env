# backend/.env (VERSÃO PARA O SERVIDOR)

# --- 1. Configurações do Banco de Dados de Produção ---
DB_HOST=localhost

# O nome do banco de dados de produção.
DB_NAME=fakenews_db

# usuário específico 
# para esta aplicação com permissões limitadas apenas ao banco 'fakenews_db'.
DB_USER=usuario_da_app_fakenews

# A senha forte e exclusiva para o usuário 'usuario_da_app_fakenews'.
DB_PASSWORD="senha_para_producao"


# --- 2. Chave de Segurança de Produção ---
# É  boa prática gerar uma nova chave secreta para o ambiente de produção.
# python3 -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY="nova_chave_secreta_gerada_para_o_servidor"


# --- 3. Configurações de E-mail de Produção ---
# As configurações do Mailtrap são apenas para teste. Elas não enviam e-mails reais.
# Você precisa substituir pelas credenciais do servidor SMTP da UFSCar ou outro serviço de produção.
MAIL_SERVER=smtp.ufscar.br
MAIL_PORT=587
MAIL_USERNAME="seu_email_institucional_ou_usuario_de_servico"
MAIL_PASSWORD="senha_do_email_ou_token_de_app"